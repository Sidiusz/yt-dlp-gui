<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Grabsy.Views.ToastWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Border x:Name="CardBorder"
                Background="{ThemeResource GrabsyBg2Brush}"
                BorderBrush="{ThemeResource GrabsyBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Width="360"
                PointerEntered="OnPointerEntered"
                PointerExited="OnPointerExited">
            <Grid>
                <Rectangle x:Name="AccentBar"
                           Width="4"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Stretch" />
                <Grid Margin="20,12,10,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   FontFamily="{StaticResource GrabsyFontFamily}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource GrabsyTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="BodyText"
                                   FontFamily="{StaticResource GrabsyFontFamily}"
                                   FontSize="12"
                                   Foreground="{ThemeResource GrabsyText3Brush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />
                    </StackPanel>
                    <Button x:Name="CloseBtn" Grid.Column="1"
                            Style="{StaticResource GrabsyButtonGhost}"
                            Width="28" Height="28" Padding="0"
                            VerticalAlignment="Center"
                            Click="OnCloseClick">
                        <FontIcon Glyph="&#xE711;" FontSize="10" />
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
