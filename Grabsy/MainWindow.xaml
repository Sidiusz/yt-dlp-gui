<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Grabsy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:Grabsy.Services"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" Background="{ThemeResource GrabsyBg1Brush}">
        <Grid.Resources>
            <svc:StringToBitmapConverter x:Key="ImgConv" />
            <svc:BoolToVisibilityConverter x:Key="BoolVis" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tray icon — right-click opens the custom Grabsy tray menu (TrayMenuWindow) -->
        <tb:TaskbarIcon x:Name="TrayIcon" ToolTipText="Grabsy" NoLeftClickDelay="True" />

        <!-- ===== Title bar ===== -->
        <Grid Grid.Row="0" Background="{ThemeResource GrabsyBg0Brush}">
            <Border x:Name="AppTitleBar" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0" Spacing="9">
                    <Image Width="18" Height="18" Source="ms-appx:///Assets/Icons/grabsy-32.png" />
                    <TextBlock Text="Grabsy" Style="{StaticResource GrabsyBodyStrong}" VerticalAlignment="Center" />
                    <TextBlock Text="yt-dlp" Style="{StaticResource GrabsyHelper}" VerticalAlignment="Center" Margin="2,1,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Content ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,18,22,22">
            <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Stretch">

                <!-- Setup banner: shown when yt-dlp / ffmpeg missing -->
                <Border x:Name="SetupBanner" Visibility="Collapsed"
                        Background="{ThemeResource GrabsyWarningDimBrush}"
                        BorderBrush="{ThemeResource GrabsyWarningBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource GrabsyRadiusLg}" Padding="16">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE896;" FontSize="16"
                                      Foreground="{ThemeResource GrabsyWarningBrush}" VerticalAlignment="Center" />
                            <TextBlock x:Name="SetupTitleText" Text="Components required"
                                       Style="{StaticResource GrabsyBodyStrong}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="SetupText" Style="{StaticResource GrabsyBody}" TextWrapping="Wrap"
                                   Text="Grabsy needs yt-dlp and ffmpeg." />
                        <ProgressBar x:Name="SetupProgress" Visibility="Collapsed" Minimum="0" Maximum="1"
                                     Foreground="{ThemeResource GrabsyAccentBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="SetupInstallButton" Content="Download &amp; install"
                                    Style="{StaticResource GrabsyButtonPrimary}" Click="OnInstallClick" />
                            <TextBlock x:Name="SetupStatus" Style="{StaticResource GrabsyBody}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- URL input -->
                <Border Style="{StaticResource GrabsyGroupCard}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="UrlLabel" Text="VIDEO URL" Style="{StaticResource GrabsyLabel}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UrlBox" Grid.Column="0" Style="{StaticResource GrabsyTextBox}"
                                     PlaceholderText="Paste a link from YouTube, X, Reddit, TikTok…"
                                     KeyDown="OnUrlKeyDown" Paste="OnUrlPaste" TextChanged="OnUrlChanged" />
                            <Button x:Name="PasteButton" Grid.Column="1" Style="{StaticResource GrabsyButtonGhost}"
                                    Click="OnPasteClick" ToolTipService.ToolTip="Paste from clipboard">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE77F;" FontSize="14" />
                            </Button>
                            <Button x:Name="FetchButton" Grid.Column="2" Content="Fetch"
                                    Style="{StaticResource GrabsyButtonPrimary}" Click="OnFetchClick" MinWidth="78" />
                        </Grid>
                        <ProgressBar x:Name="FetchProgress" IsIndeterminate="True" Visibility="Collapsed"
                                     Foreground="{ThemeResource GrabsyAccentBrush}" />
                        <TextBlock x:Name="FetchError" Style="{StaticResource GrabsyHelper}" Visibility="Collapsed"
                                   Foreground="{ThemeResource GrabsyDangerBrush}" />
                    </StackPanel>
                </Border>

                <!-- Info + options: always shown, disabled (in code) until a link is probed -->
                <Border x:Name="InfoCard" Style="{StaticResource GrabsyGroupCard}">
                    <StackPanel Spacing="14">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="160" Height="90" CornerRadius="{StaticResource GrabsyRadiusMd}"
                                    Background="{ThemeResource GrabsyBgInputBrush}">
                                <Image x:Name="Thumbnail" Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock x:Name="InfoTitle" Style="{StaticResource GrabsyBodyStrong}"
                                           FontSize="15" Foreground="{ThemeResource GrabsyTextBrush}"
                                           TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="InfoUploader" Style="{StaticResource GrabsyHelper}" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE916;" FontSize="11"
                                              Foreground="{ThemeResource GrabsyText3Brush}" VerticalAlignment="Center" />
                                    <TextBlock x:Name="InfoDuration" Style="{StaticResource GrabsyHelper}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource GrabsyHairline}" />

                        <!-- Options -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ModeCombo" Grid.Column="0" SelectionChanged="OnModeChanged"
                                      Style="{StaticResource GrabsyComboBox}" HorizontalAlignment="Stretch">
                                <ComboBoxItem x:Name="ModeBoth" Content="Video &amp; Audio" Tag="videoaudio" />
                                <ComboBoxItem x:Name="ModeAudioItem" Content="Just Audio" Tag="audio" />
                                <ComboBoxItem x:Name="ModeVideoItem" Content="Just Video" Tag="videoonly" />
                            </ComboBox>
                            <ComboBox x:Name="QualityCombo" Grid.Column="1"
                                      Style="{StaticResource GrabsyComboBox}" HorizontalAlignment="Stretch" />
                            <ComboBox x:Name="ContainerCombo" Grid.Column="2"
                                      Style="{StaticResource GrabsyComboBox}" HorizontalAlignment="Stretch" />
                        </Grid>

                        <!-- More options -->
                        <Expander x:Name="MoreOptions" HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch" Background="{ThemeResource GrabsyBg1Brush}">
                            <Expander.Header>
                                <TextBlock x:Name="MoreOptionsHeader" Text="More options" Style="{StaticResource GrabsyBody}" />
                            </Expander.Header>
                            <StackPanel Spacing="12" Margin="0,4,0,0">
                                <Grid x:Name="CodecRow" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CodecLabel" Text="Video codec" Style="{StaticResource GrabsyBody}" VerticalAlignment="Center" />
                                    <ComboBox x:Name="CodecCombo" Grid.Column="1" HorizontalAlignment="Stretch"
                                              Style="{StaticResource GrabsyComboBox}">
                                        <ComboBoxItem Content="Automatic (best)" Tag="auto" />
                                        <ComboBoxItem Content="H.264 / AVC (most compatible)" Tag="h264" />
                                        <ComboBoxItem Content="H.265 / HEVC" Tag="h265" />
                                        <ComboBoxItem Content="VP9" Tag="vp9" />
                                        <ComboBoxItem Content="AV1 (smallest)" Tag="av1" />
                                    </ComboBox>
                                </Grid>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TrimLabel" Text="Trim range" Style="{StaticResource GrabsyBody}" VerticalAlignment="Center" />
                                    <TextBox x:Name="TrimStart" Grid.Column="1" Style="{StaticResource GrabsyTextBox}"
                                             PlaceholderText="start e.g. 0:30" />
                                    <TextBlock Grid.Column="2" Text="→" Style="{StaticResource GrabsyBody}" VerticalAlignment="Center" />
                                    <TextBox x:Name="TrimEnd" Grid.Column="3" Style="{StaticResource GrabsyTextBox}"
                                             PlaceholderText="end e.g. 1:45" />
                                </Grid>
                                <TextBlock x:Name="TrimHelpText" Text="Leave both empty for the full video. Format: SS, M:SS or H:MM:SS."
                                           Style="{StaticResource GrabsyHelper}" />

                                <Border Style="{StaticResource GrabsyHairline}" />

                                <!-- Audio tracks (only when the source has several languages) -->
                                <StackPanel x:Name="AudioSection" Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="AudioTracksHeader" Text="Audio tracks" Style="{StaticResource GrabsyBodyStrong}" />
                                        <Button x:Name="AudioAllButton" Content="All" Style="{StaticResource GrabsyButtonSm}"
                                                Click="OnSelectAllAudio" />
                                        <Button x:Name="AudioNoneButton" Content="None" Style="{StaticResource GrabsyButtonSm}"
                                                Click="OnSelectNoneAudio" />
                                    </StackPanel>
                                    <StackPanel x:Name="AudioTracksPanel" Spacing="2" />
                                    <TextBlock x:Name="AudioTracksEmpty" Style="{StaticResource GrabsyHelper}"
                                               Text="Only one audio track available." />
                                </StackPanel>

                                <!-- Subtitles (only when available) -->
                                <StackPanel x:Name="SubsSection" Spacing="6">
                                    <Grid>
                                        <TextBlock x:Name="SubsHeader" Text="Subtitles" Style="{StaticResource GrabsyBodyStrong}" VerticalAlignment="Center" />
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                            <Button x:Name="SubsAllButton" Content="All" Style="{StaticResource GrabsyButtonSm}"
                                                    Click="OnSelectAllSubs" />
                                            <Button x:Name="SubsNoneButton" Content="None" Style="{StaticResource GrabsyButtonSm}"
                                                    Click="OnSelectNoneSubs" />
                                            <ComboBox x:Name="SubModeCombo" MinWidth="130" Style="{StaticResource GrabsyComboBox}">
                                                <ComboBoxItem x:Name="SubModeEmbed" Content="Embed in video" Tag="embed" />
                                                <ComboBoxItem x:Name="SubModeWrite" Content="Separate .srt" Tag="write" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel x:Name="SubtitlesPanel" Spacing="2" />
                                    <TextBlock x:Name="SubtitlesEmpty" Style="{StaticResource GrabsyHelper}"
                                               Text="No subtitles available for this video." />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Button x:Name="DownloadButton" Content="Download" Style="{StaticResource GrabsyButtonPrimary}"
                                HorizontalAlignment="Stretch" Click="OnDownloadClick" />
                    </StackPanel>
                </Border>

                <!-- Downloads -->
                <Border Style="{StaticResource GrabsyGroupCard}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="DownloadsLabel" Text="DOWNLOADS" Style="{StaticResource GrabsyLabel}" VerticalAlignment="Center" />
                        <TextBlock x:Name="EmptyHint" Style="{StaticResource GrabsyHelper}"
                                   Text="No downloads yet. Paste a link above to get started." />
                        <ItemsControl x:Name="DownloadsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource GrabsyBg2Brush}" Margin="0,0,0,8"
                                            BorderBrush="{ThemeResource GrabsyBorderSubtleBrush}" BorderThickness="1"
                                            CornerRadius="{StaticResource GrabsyRadiusLg}" Padding="12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Thumbnail doubles as the Play button when finished -->
                                            <Button Grid.Column="0" Style="{StaticResource GrabsyThumbButton}"
                                                    Click="OnJobOpen" ToolTipService.ToolTip="Play video"
                                                    IsEnabled="{Binding CanOpen}">
                                                <Border Width="88" Height="50" CornerRadius="{StaticResource GrabsyRadiusMd}"
                                                        Background="{ThemeResource GrabsyBgInputBrush}">
                                                    <Grid>
                                                        <Image Source="{Binding ThumbnailUrl, Converter={StaticResource ImgConv}}" Stretch="UniformToFill" />
                                                        <Border Background="#66000000" CornerRadius="{StaticResource GrabsyRadiusMd}"
                                                                Visibility="{Binding CanOpen, Converter={StaticResource BoolVis}}">
                                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE768;" FontSize="20"
                                                                      Foreground="White" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                            <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource GrabsyBodyStrong}"
                                                           MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                                             IsIndeterminate="{Binding Indeterminate}"
                                                             Foreground="{ThemeResource GrabsyAccentBrush}"
                                                             Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Format}" Style="{StaticResource GrabsyHelper}" />
                                                    <TextBlock Text="·" Style="{StaticResource GrabsyHelper}" />
                                                    <TextBlock Text="{Binding Status}" Style="{StaticResource GrabsyHelper}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding SizeDate}" Style="{StaticResource GrabsyHelper}"
                                                           Foreground="{ThemeResource GrabsyText2Brush}"
                                                           Visibility="{Binding HasSizeDate, Converter={StaticResource BoolVis}}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource GrabsyIconButton}" Click="OnJobCancel"
                                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"
                                                        ToolTipService.ToolTip="Cancel">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" FontSize="14" />
                                                </Button>
                                                <Button Style="{StaticResource GrabsyIconButtonDangerFilled}" Click="OnJobDelete"
                                                        ToolTipService.ToolTip="Remove from list">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" FontSize="14" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== Bottom status bar: live stats + quick actions ===== -->
        <Border Grid.Row="2"
                Background="{ThemeResource GrabsyBg0Brush}"
                BorderBrush="{ThemeResource GrabsyBorderSubtleBrush}" BorderThickness="0,1,0,0"
                Padding="18,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Stats (downloading / done / errors) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE896;" FontSize="13"
                                  Foreground="{ThemeResource GrabsyAccentBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatDownloading" Text="0" Style="{StaticResource GrabsyBodyStrong}"
                                   Foreground="{ThemeResource GrabsyAccentBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatDownloadingLbl" Text="downloading" Style="{StaticResource GrabsyHelper}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE73E;" FontSize="13"
                                  Foreground="{ThemeResource GrabsySuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatDone" Text="0" Style="{StaticResource GrabsyBodyStrong}"
                                   Foreground="{ThemeResource GrabsySuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatDoneLbl" Text="done" Style="{StaticResource GrabsyHelper}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEA39;" FontSize="13"
                                  Foreground="{ThemeResource GrabsyDangerBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatErrors" Text="0" Style="{StaticResource GrabsyBodyStrong}"
                                   Foreground="{ThemeResource GrabsyDangerBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatErrorsLbl" Text="errors" Style="{StaticResource GrabsyHelper}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Quick actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button x:Name="DockOpenFolder" Style="{StaticResource GrabsyIconButton}" Click="OnDockOpenFolder"
                            ToolTipService.ToolTip="Open video folder">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE838;" FontSize="14" />
                    </Button>
                    <Button x:Name="SettingsButton" Style="{StaticResource GrabsyIconButton}" Click="OnSettingsClick"
                            ToolTipService.ToolTip="Settings">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
