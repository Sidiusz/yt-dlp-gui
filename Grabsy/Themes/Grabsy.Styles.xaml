    <!-- Compact toggle (replaces ToggleSwitch where we only need on/off, no content column) -->
    <!--
        WinUI 3 ToggleButton uses a single CommonStates group with combined states
        (Checked, CheckedPointerOver, CheckedPressed). It never calls GoToState("Unchecked").
        Unchecking transitions to Normal/PointerOver/Pressed — so those states must carry
        the reset animations. Using pure ObjectAnimationUsingKeyFrames (no Setters) so
        every state explicitly drives all three visual properties.
    -->
    <Style x:Key="GrabsyMiniToggle" TargetType="ToggleButton">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="20" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <!-- Base = OFF look, theme-aware. Colors are driven by
                             VisualState.Setters (auto-reverted on state exit and
                             re-resolved per theme); storyboards only move the knob. -->
                        <Border x:Name="Track"
                                CornerRadius="10"
                                Background="{ThemeResource GrabsyBg3Brush}"
                                BorderBrush="{ThemeResource GrabsyBorderBrush}"
                                BorderThickness="1" />
                        <Ellipse x:Name="Knob"
                                 Width="14" Height="14"
                                 Fill="{ThemeResource GrabsyText2Brush}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Margin="3,0,0,0">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="KnobTransform" X="0" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">

                                <!-- Slide the knob over 0.15s ONLY when crossing the
                                     on/off boundary. A blanket (From/To-less) transition
                                     also fired on hover/press, and since Brushes cannot
                                     interpolate the track flashed its base grey for the
                                     whole transition. States snap X instantly (Duration 0);
                                     these explicit transitions supply the slide. -->
                                <VisualStateGroup.Transitions>
                                    <VisualTransition From="Normal" To="Checked" GeneratedDuration="0:0:0.15">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                    <VisualTransition From="Checked" To="Normal" GeneratedDuration="0:0:0.15">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                    <VisualTransition From="PointerOver" To="CheckedPointerOver" GeneratedDuration="0:0:0.15">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                    <VisualTransition From="CheckedPointerOver" To="PointerOver" GeneratedDuration="0:0:0.15">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                    <VisualTransition From="Pressed" To="Checked" GeneratedDuration="0:0:0.15">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                    <VisualTransition From="Pressed" To="CheckedPointerOver" GeneratedDuration="0:0:0.15">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                    <VisualTransition From="CheckedPressed" To="Normal" GeneratedDuration="0:0:0.15">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                    <VisualTransition From="CheckedPressed" To="PointerOver" GeneratedDuration="0:0:0.15">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                </VisualStateGroup.Transitions>

                                <!-- OFF states: knob at 0; base colors apply -->
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Track.BorderBrush" Value="{ThemeResource GrabsyBorderStrongBrush}" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Track.BorderBrush" Value="{ThemeResource GrabsyBorderStrongBrush}" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource GrabsyBg2Brush}" />
                                        <Setter Target="Knob.Fill" Value="{ThemeResource GrabsyText4Brush}" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <!-- ON states: knob at 16, accent colors -->
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="Track.BorderBrush" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="Knob.Fill" Value="{ThemeResource GrabsyOnAccentBrush}" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="16" Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="Track.BorderBrush" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="Knob.Fill" Value="{ThemeResource GrabsyOnAccentBrush}" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="16" Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="CheckedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource GrabsyAccentPressedBrush}" />
                                        <Setter Target="Track.BorderBrush" Value="{ThemeResource GrabsyAccentPressedBrush}" />
                                        <Setter Target="Knob.Fill" Value="{ThemeResource GrabsyOnAccentBrush}" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="16" Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="CheckedDisabled">
                                    <VisualState.Setters>
                                        <Setter Target="Track.Background" Value="{ThemeResource GrabsyAccentDimStrongBrush}" />
                                        <Setter Target="Knob.Fill" Value="{ThemeResource GrabsyText4Brush}" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="16" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


