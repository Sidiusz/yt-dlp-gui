        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <Border x:Name="HoverOverlay"
                                Background="{ThemeResource GrabsyBgHoverBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0" />
                        <Grid Padding="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="16" Height="16"
                                  VerticalAlignment="Center" Margin="0,0,10,0">
                                <Ellipse x:Name="OuterEllipse"
                                         Stroke="{ThemeResource GrabsyBorderBrush}"
                                         StrokeThickness="1.5" Fill="Transparent" />
                                <Ellipse x:Name="InnerEllipse" Width="8" Height="8"
                                         Fill="{ThemeResource GrabsyAccentBrush}"
                                         Visibility="Collapsed" />
                            </Grid>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="HoverOverlay.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="HoverOverlay.Opacity" Value="0.35" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="HoverOverlay.Opacity" Value="0.55" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyCodecSelectedBrush}" />
                                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="OuterEllipse.Stroke" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="InnerEllipse.Visibility" Value="Visible" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource GrabsyTextBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Unchecked">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="Transparent" />
                                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource GrabsyBorderSubtleBrush}" />
                                        <Setter Target="OuterEllipse.Stroke" Value="{ThemeResource GrabsyBorderBrush}" />
                                        <Setter Target="InnerEllipse.Visibility" Value="Collapsed" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource GrabsyText2Brush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Indeterminate" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Thumbnail-as-Play button: scales up + accent outline on hover -->
    <Style x:Key="GrabsyThumbButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder" CornerRadius="{StaticResource GrabsyRadiusMd}"
                            BorderBrush="Transparent" BorderThickness="2"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter Content="{TemplateBinding Content}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Scale.ScaleX" Value="1.08" />
                                        <Setter Target="Scale.ScaleY" Value="1.08" />
                                        <Setter Target="RootBorder.BorderBrush" Value="{ThemeResource GrabsyAccentBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Scale.ScaleX" Value="1.03" />
                                        <Setter Target="Scale.ScaleY" Value="1.03" />
                                        <Setter Target="RootBorder.BorderBrush" Value="{ThemeResource GrabsyAccentPressedBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
