<?xml version="1.0" encoding="utf-8"?>
<!--
  Grabsy control styles. Targets the same classes used in your existing
  XAML — Button, ToggleButton, TextBox, ComboBox, ToggleSwitch, Slider —
  plus named styles for IconButtons, toolbars, cards, kbd, etc.

  Drop into Themes/ and merge from App.xaml (after Grabsy.Tokens.xaml).
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <!-- ============================================================
         Implicit font application
         ============================================================
         WinUI 3 does not inherit FontFamily down arbitrary visual trees,
         so apply the Grabsy font as the implicit default for every
         text-bearing control. Named TextBlock styles override this — so
         each named TextBlock style below also re-sets FontFamily to the
         same token (mono style keeps its monospace family).
    -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GrabsyFontFamily}" />
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource GrabsyFontFamily}" />
    </Style>
    <Style TargetType="ContentPresenter">
        <Setter Property="FontFamily" Value="{StaticResource GrabsyFontFamily}" />
    </Style>

    <!-- ============================================================
         Buttons
         ============================================================
         GrabsyButton          : default button, neutral bg-3 surface
         GrabsyButtonPrimary   : accent CTA
         GrabsyButtonGhost     : transparent with subtle border
         GrabsyButtonDanger    : danger CTA (stop, delete)
    -->
    <Style x:Key="GrabsyButton" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource GrabsyBg3Brush}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyTextBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource GrabsyRadiusSm}" />
        <Setter Property="Padding" Value="12,0,12,0" />
        <Setter Property="Height" Value="{StaticResource GrabsyControlHeight}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="{StaticResource GrabsyFontWeightStrong}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyBgHoverBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyBgActiveBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NOTE: implicit Button style removed — broke ComboBox internal DropDownGlyph button.
         Use Style="{StaticResource GrabsyButton}" explicitly. -->
    <!--<Style TargetType="Button" BasedOn="{StaticResource GrabsyButton}" />-->

    <Style x:Key="GrabsyButtonPrimary" TargetType="Button" BasedOn="{StaticResource GrabsyButton}">
        <Setter Property="Background" Value="{ThemeResource GrabsyAccentBrush}" />
        <!-- White text on the accent; the inherited template swaps Background
             to hover/pressed stops but leaves foreground. -->
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyAccentHoverBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyAccentPressedBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GrabsyButtonGhost" TargetType="Button" BasedOn="{StaticResource GrabsyButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource GrabsyBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyText2Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyBg2Brush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource GrabsyTextBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyBg3Brush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GrabsyButtonDanger" TargetType="Button" BasedOn="{StaticResource GrabsyButtonPrimary}">
        <Setter Property="Background" Value="{ThemeResource GrabsyDangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyDangerHoverBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GrabsyButtonSm" TargetType="Button" BasedOn="{StaticResource GrabsyButton}">
        <Setter Property="Height" Value="{StaticResource GrabsyControlHeightSm}" />
        <Setter Property="Padding" Value="10,0,10,0" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- ============================================================
         Icon Button — 32x32 transparent tool button used in overlays
         ============================================================
         Default (no Tag)         : neutral
         Tag = "active"           : currently-selected tool (accent fill)
         Tag = "danger"           : record / stop hue on hover
    -->
    <Style x:Key="GrabsyIconButton" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource GrabsyToolButtonSize}" />
        <Setter Property="Height" Value="{StaticResource GrabsyToolButtonSize}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource GrabsyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyText2Brush}" />
        <Setter Property="CornerRadius" Value="{StaticResource GrabsyRadiusMd}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyBg3Brush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource GrabsyTextBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyBgActiveBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Opacity" Value="0.35" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GrabsyIconButtonActive" TargetType="Button" BasedOn="{StaticResource GrabsyIconButton}">
        <Setter Property="Background" Value="{ThemeResource GrabsyAccentDimBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource GrabsyAccentBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyAccentBrush}" />
    </Style>

    <!-- Selected tool: amber tint + amber border that survives PointerOver.
         The base GrabsyIconButton template's PointerOver state forces
         Background to grey, which overwrites the inline amber. This style
         supplies its own template with amber stops for Normal / Hover /
         Pressed so the active state never reads as grey on hover. -->
    <Style x:Key="GrabsyIconButtonSelected" TargetType="Button" BasedOn="{StaticResource GrabsyIconButton}">
        <Setter Property="Background" Value="{ThemeResource GrabsyAccentDimBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource GrabsyAccentBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyAccentBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyAccentDimStrongBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="White" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Opacity" Value="0.35" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GrabsyIconButtonDanger" TargetType="Button" BasedOn="{StaticResource GrabsyIconButton}">
        <Setter Property="Foreground" Value="{ThemeResource GrabsyDangerBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyDangerDimBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyDangerDimBrush}" />
                                        <Setter Target="RootGrid.Opacity" Value="0.8" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filled danger icon button: solid red, white glyph (matches the Reset CTA) -->
    <Style x:Key="GrabsyIconButtonDangerFilled" TargetType="Button" BasedOn="{StaticResource GrabsyIconButton}">
        <Setter Property="Background" Value="{ThemeResource GrabsyDangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyDangerHoverBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyDangerHoverBrush}" />
                                        <Setter Target="RootGrid.Opacity" Value="0.85" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToggleButton variant (used by Draw toggle in HUD) -->
    <Style x:Key="GrabsyIconToggle" TargetType="ToggleButton">
        <Setter Property="Width" Value="{StaticResource GrabsyToolButtonSize}" />
        <Setter Property="Height" Value="{StaticResource GrabsyToolButtonSize}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyText2Brush}" />
        <Setter Property="CornerRadius" Value="{StaticResource GrabsyRadiusMd}" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            x:Name="ContentPresenter"
                            Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyBg3Brush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource GrabsyTextBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyBgActiveBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyAccentDimBrush}" />
                                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource GrabsyAccentBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyAccentDimStrongBrush}" />
                                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource GrabsyAccentBrush}" />
                                        <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource GrabsyAccentBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource GrabsyAccentDimStrongBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         Text input
         ============================================================ -->
    <Style x:Key="GrabsyTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{ThemeResource GrabsyBgInputBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource GrabsyBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource GrabsyRadiusSm}" />
        <Setter Property="Padding" Value="10,6,10,6" />
        <Setter Property="MinHeight" Value="{StaticResource GrabsyControlHeight}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="SelectionHighlightColor" Value="{ThemeResource GrabsyAccentBrush}" />
    </Style>
    <!--<Style TargetType="TextBox" BasedOn="{StaticResource GrabsyTextBox}" />-->

    <!-- ============================================================
         Combo box
         ============================================================ -->
    <Style x:Key="GrabsyComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{ThemeResource GrabsyBgInputBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource GrabsyBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource GrabsyRadiusSm}" />
        <Setter Property="MinHeight" Value="{StaticResource GrabsyControlHeight}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,4,8,4" />
    </Style>
    <!--<Style TargetType="ComboBox" BasedOn="{StaticResource GrabsyComboBox}" />-->

    <!-- ============================================================
         ToggleSwitch — strip the Header label area to look like our pill
         ============================================================ -->
    <Style x:Key="GrabsyToggleSwitch" TargetType="ToggleSwitch">
        <Setter Property="OffContent" Value="" />
        <Setter Property="OnContent" Value="" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyTextBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ============================================================
         Window-level surfaces
         ============================================================ -->

    <!-- Toolbar pill (capture overlay + HUD share this) -->
    <Style x:Key="GrabsyToolbar" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource GrabsyBg1Brush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource GrabsyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource GrabsyRadiusLg}" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <!-- Vertical separator inside toolbar -->
    <Style x:Key="GrabsyToolbarSeparator" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Background" Value="{ThemeResource GrabsyBorderBrush}" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="GrabsyToolbarSeparatorHorizontal" TargetType="Border">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{ThemeResource GrabsyBorderBrush}" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Group card used inside Settings -->
    <Style x:Key="GrabsyGroupCard" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource GrabsyBg2Brush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource GrabsyBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource GrabsyRadiusLg}" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <!-- Hairline divider used between rows -->
    <Style x:Key="GrabsyHairline" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{ThemeResource GrabsyBorderSubtleBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- ============================================================
         Text styles
         ============================================================ -->

    <!-- 11 / 600 uppercase label -->
    <Style x:Key="GrabsyLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GrabsyFontFamily}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyText3Brush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="{StaticResource GrabsyFontWeightLabel}" />
        <Setter Property="CharacterSpacing" Value="60" />
    </Style>

    <!-- 13 / 500 strong body -->
    <Style x:Key="GrabsyBodyStrong" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GrabsyFontFamily}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="{StaticResource GrabsyFontWeightStrong}" />
    </Style>

    <!-- 13 body -->
    <Style x:Key="GrabsyBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GrabsyFontFamily}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyText2Brush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- 11 helper (parameter descriptions) -->
    <Style x:Key="GrabsyHelper" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GrabsyFontFamily}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyText3Brush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- 20 section title -->
    <Style x:Key="GrabsySectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GrabsyFontFamily}" />
        <Setter Property="Foreground" Value="{ThemeResource GrabsyTextBrush}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="{StaticResource GrabsyFontWeightTitle}" />
    </Style>

    <!-- Monospace -->
    <Style x:Key="GrabsyMono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Mono, JetBrains Mono, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
